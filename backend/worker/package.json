    "start": "node dist/main.js",
    "start:dev": "tsx src/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1075.0",
    "@aws-sdk/client-sqs": "3.1075.0",
    "@mediapipe/tasks-vision": "0.10.35",
    "openai": "6.45.0"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
