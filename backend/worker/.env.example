DATABASE_URL=postgresql://init:secret@localhost:5432/init
REDIS_URL=redis://localhost:6379
AWS_REGION=ap-northeast-2
S3_BUCKET=init-dev-bucket
SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/init-ai-worker
OPENAI_API_KEY=replace-with-secret
JWT_SECRET=replace-with-secret

AI_SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/init-ai-worker
AI_PROVIDER_API_KEY=replace-with-secret
S3_BUCKET_NAME=init-dev-bucket
WORKER_BATCH_SIZE=1
WORKER_POLL_INTERVAL_MS=1000
WORKER_REPOSITORY_MODE=prisma
# Use WORKER_REPOSITORY_MODE=memory only for isolated local/unit tests.
# PRISMA_CLIENT_MODULE defaults to the API package's @prisma/client.
PRISMA_CLIENT_MODULE=
