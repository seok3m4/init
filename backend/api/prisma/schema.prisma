generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  COMPANY
  CANDIDATE

  @@map("user_type")
}

enum AuthProvider {
  LOCAL
  GOOGLE

  @@map("auth_provider")
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DEACTIVATED

  @@map("user_status")
}

enum PostingStatus {
  DRAFT
  OPEN
  CLOSING_SOON
  CLOSED
  ARCHIVED

  @@map("posting_status")
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  INTERVIEW_WAITING
  INTERVIEW_DONE
  COMPLETED
  CANCELED

  @@map("application_status")
}

enum DocumentStatus {
  NOT_SUBMITTED
  SUBMITTED
  EXTRACTING
  EXTRACTED
  FAILED

  @@map("document_status")
}

enum InterviewStatus {
  NOT_READY
  READY
  IN_PROGRESS
  COMPLETED
  FAILED

  @@map("interview_status")
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED

  @@map("report_status")
}

enum ScreeningDecision {
  UNDECIDED
  PASS
  HOLD
  FAIL

  @@map("screening_decision")
}

enum InterviewType {
  MOCK
  RECRUITING

  @@map("interview_type")
}

enum ReportType {
  MOCK_INTERVIEW_REPORT
  RECRUITING_REPORT

  @@map("report_type")
}

enum DocumentType {
  RESUME
  PORTFOLIO

  @@map("document_type")
}

enum ConsentType {
  PRIVACY_COLLECTION
  AI_DOCUMENT_ANALYSIS
  AI_INTERVIEW_RECORDING

  @@map("consent_type")
}

enum QuestionType {
  INTRO
  TECHNICAL
  EXPERIENCE
  SITUATION
  FOLLOW_UP
  CLOSING

  @@map("question_type")
}

enum NotificationChannel {
  EMAIL
  IN_APP

  @@map("notification_channel")
}

enum AiProcessType {
  DOCUMENT_EXTRACT
  STT
  FOLLOW_UP
  REPORT_GENERATE
  EMBEDDING

  @@map("ai_process_type")
}

enum AiProcessStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED

  @@map("ai_process_status")
}

enum GuardrailResult {
  PASS
  BLOCKED
  REGENERATED

  @@map("guardrail_result")
}

enum EmbeddingSourceType {
  POSTING_JD
  CRITERION_TAG
  QUESTION
  APPLICATION_DOCUMENT
  INTERVIEW_ANSWER
  EVALUATION_REPORT

  @@map("embedding_source_type")
}

model User {
  userId         Int             @id @default(autoincrement()) @map("user_id")
  email          String          @unique @db.VarChar(255)
  passwordHash   String?         @map("password_hash") @db.VarChar(255)
  userType       UserType        @map("user_type")
  name           String          @db.VarChar(100)
  phone          String?         @db.VarChar(50)
  status         UserStatus      @default(PENDING)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  authProvider   AuthProvider    @default(LOCAL) @map("auth_provider")
  providerUserId String?         @map("provider_user_id") @db.VarChar(255)
  ownedCompany   Company?        @relation("CompanyOwner")
  candidateProfile CandidateProfile?
  fileAssets     FileAsset[]
  manualEvaluations ManualEvaluation[]
  notifications  Notification[]

  @@map("users")
}

model Company {
  companyId                  Int        @id @default(autoincrement()) @map("company_id")
  ownerUserId                Int        @unique @map("owner_user_id")
  name                       String     @db.VarChar(150)
  businessRegistrationNumber String     @unique @map("business_registration_number") @db.VarChar(10)
  verificationStatus         String     @map("verification_status") @db.VarChar(30)
  industry                   String?    @db.VarChar(100)
  profile                    String?
  talentProfile              String?    @map("talent_profile")
  evaluationPolicy           String?    @map("evaluation_policy")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")
  owner                      User       @relation("CompanyOwner", fields: [ownerUserId], references: [userId])
  postings                   Posting[]
  questions                  Question[]

  @@map("companies")
}

model FileAsset {
  fileId        Int       @id @default(autoincrement()) @map("file_id")
  ownerUserId   Int       @map("owner_user_id")
  storageKey    String    @map("storage_key") @db.VarChar(500)
  originalName  String    @map("original_name") @db.VarChar(255)
  mimeType      String    @map("mime_type") @db.VarChar(100)
  sizeBytes     Int       @map("size_bytes")
  status        String    @db.VarChar(30)
  createdAt     DateTime  @default(now()) @map("created_at")
  owner         User      @relation(fields: [ownerUserId], references: [userId])
  candidateProfiles CandidateProfile[]
  documents     ApplicationDocument[]
  videoAnswers   InterviewAnswer[] @relation("VideoFile")
  audioAnswers   InterviewAnswer[] @relation("AudioFile")

  @@map("file_assets")
}

model CandidateProfile {
  candidateId         Int            @id @default(autoincrement()) @map("candidate_id")
  userId              Int            @unique @map("user_id")
  defaultResumeFileId Int?           @map("default_resume_file_id")
  portfolioUrl        String?        @map("portfolio_url") @db.VarChar(500)
  githubUrl           String?        @map("github_url") @db.VarChar(500)
  summary             String?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  user                User           @relation(fields: [userId], references: [userId])
  defaultResumeFile   FileAsset?     @relation(fields: [defaultResumeFileId], references: [fileId])
  applications        Application[]
  interviewSessions   InterviewSession[]

  @@map("candidate_profiles")
}

model Posting {
  postingId      Int                   @id @default(autoincrement()) @map("posting_id")
  companyId      Int                   @map("company_id")
  title          String                @db.VarChar(200)
  jobRole        String                @map("job_role") @db.VarChar(100)
  jobDescription String?               @map("job_description")
  startsOn       DateTime?             @map("starts_on") @db.Date
  endsOn         DateTime?             @map("ends_on") @db.Date
  status         PostingStatus         @default(DRAFT)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  company        Company               @relation(fields: [companyId], references: [companyId])
  criteria       EvaluationCriterion[]
  questions      Question[]
  applications   Application[]

  @@index([companyId, status])
  @@map("postings")
}

model CriterionTag {
  tagId       Int                   @id @default(autoincrement()) @map("tag_id")
  jobRole     String                @map("job_role") @db.VarChar(100)
  name        String                @db.VarChar(100)
  description String?
  category    String                @db.VarChar(80)
  isActive    Boolean               @default(true) @map("is_active")
  sortOrder   Int                   @map("sort_order")
  criteria    EvaluationCriterion[]

  @@map("criterion_tags")
}

model EvaluationCriterion {
  criterionId Int           @id @default(autoincrement()) @map("criterion_id")
  postingId   Int           @map("posting_id")
  tagId       Int           @map("tag_id")
  weight      Int
  passScore   Int?          @map("pass_score")
  sortOrder   Int           @map("sort_order")
  posting     Posting       @relation(fields: [postingId], references: [postingId])
  tag         CriterionTag  @relation(fields: [tagId], references: [tagId])
  questions   Question[]
  reportScores ReportScore[]

  @@map("evaluation_criteria")
}

model Question {
  questionId   Int                  @id @default(autoincrement()) @map("question_id")
  companyId    Int                  @map("company_id")
  postingId    Int?                 @map("posting_id")
  criterionId  Int?                 @map("criterion_id")
  questionType QuestionType         @map("question_type")
  content      String
  isActive     Boolean              @default(true) @map("is_active")
  company      Company              @relation(fields: [companyId], references: [companyId])
  posting      Posting?             @relation(fields: [postingId], references: [postingId])
  criterion    EvaluationCriterion? @relation(fields: [criterionId], references: [criterionId])
  answers      InterviewAnswer[]

  @@map("question_bank")
}

model Application {
  applicationId      Int                @id @default(autoincrement()) @map("application_id")
  postingId          Int                @map("posting_id")
  candidateId        Int                @map("candidate_id")
  applicationStatus  ApplicationStatus  @default(SUBMITTED) @map("application_status")
  documentStatus     DocumentStatus     @default(NOT_SUBMITTED) @map("document_status")
  interviewStatus    InterviewStatus    @default(NOT_READY) @map("interview_status")
  reportStatus       ReportStatus       @default(PENDING) @map("report_status")
  screeningDecision  ScreeningDecision? @default(UNDECIDED) @map("screening_decision")
  screeningMemo      String?            @map("screening_memo")
  submittedAt        DateTime?          @map("submitted_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  posting            Posting            @relation(fields: [postingId], references: [postingId])
  candidate          CandidateProfile   @relation(fields: [candidateId], references: [candidateId])
  documents          ApplicationDocument[]
  consentRecords     ConsentRecord[]
  interviewSessions  InterviewSession[]
  evaluationReports  EvaluationReport[]
  notifications      Notification[]
  aiProcessLogs      AiProcessLog[]

  @@unique([postingId, candidateId])
  @@index([postingId, applicationStatus])
  @@map("applications")
}

model ApplicationDocument {
  documentId    Int            @id @default(autoincrement()) @map("document_id")
  applicationId Int            @map("application_id")
  fileId        Int?           @map("file_id")
  documentType  DocumentType   @map("document_type")
  parseStatus   DocumentStatus @map("parse_status")
  extractedText String?        @map("extracted_text")
  uploadedAt    DateTime       @default(now()) @map("uploaded_at")
  application   Application    @relation(fields: [applicationId], references: [applicationId])
  file          FileAsset?     @relation(fields: [fileId], references: [fileId])

  @@map("application_documents")
}

model ConsentRecord {
  consentId     Int         @id @default(autoincrement()) @map("consent_id")
  applicationId Int         @map("application_id")
  consentType   ConsentType @map("consent_type")
  agreed        Boolean
  agreedAt      DateTime?   @map("agreed_at")
  application   Application @relation(fields: [applicationId], references: [applicationId])

  @@map("consent_records")
}

model InterviewSession {
  sessionId        Int              @id @default(autoincrement()) @map("session_id")
  applicationId    Int?             @map("application_id")
  candidateId      Int              @map("candidate_id")
  interviewType    InterviewType    @map("interview_type")
  status           InterviewStatus  @default(NOT_READY)
  showQuestionText Boolean          @default(false) @map("show_question_text")
  startedAt        DateTime?        @map("started_at")
  completedAt      DateTime?        @map("completed_at")
  application      Application?     @relation(fields: [applicationId], references: [applicationId])
  candidate        CandidateProfile @relation(fields: [candidateId], references: [candidateId])
  answers          InterviewAnswer[]
  evaluationReports EvaluationReport[]
  aiProcessLogs    AiProcessLog[]

  @@map("interview_sessions")
}

model InterviewAnswer {
  answerId        Int              @id @default(autoincrement()) @map("answer_id")
  sessionId       Int              @map("session_id")
  questionId      Int?             @map("question_id")
  videoFileId     Int?             @map("video_file_id")
  audioFileId     Int?             @map("audio_file_id")
  transcript      String?
  durationSeconds Int?             @map("duration_seconds")
  submittedAt     DateTime?        @map("submitted_at")
  session         InterviewSession @relation(fields: [sessionId], references: [sessionId])
  question        Question?        @relation(fields: [questionId], references: [questionId])
  videoFile       FileAsset?       @relation("VideoFile", fields: [videoFileId], references: [fileId])
  audioFile       FileAsset?       @relation("AudioFile", fields: [audioFileId], references: [fileId])
  followUpQuestions FollowUpQuestion[]
  reportEvidences ReportEvidence[]

  @@map("interview_answers")
}

model FollowUpQuestion {
  followUpId       Int             @id @default(autoincrement()) @map("follow_up_id")
  answerId         Int             @map("answer_id")
  content          String
  generationStatus String          @map("generation_status") @db.VarChar(40)
  createdAt        DateTime        @default(now()) @map("created_at")
  answer           InterviewAnswer @relation(fields: [answerId], references: [answerId])

  @@map("follow_up_questions")
}

model EvaluationReport {
  reportId      Int           @id @default(autoincrement()) @map("report_id")
  applicationId Int?          @map("application_id")
  sessionId     Int?          @map("session_id")
  reportType    ReportType    @map("report_type")
  status        ReportStatus  @default(PENDING)
  totalScore    Int?          @map("total_score")
  summary       String?
  generatedAt   DateTime?     @map("generated_at")
  application   Application?  @relation(fields: [applicationId], references: [applicationId])
  session       InterviewSession? @relation(fields: [sessionId], references: [sessionId])
  scores        ReportScore[]
  manualEvaluations ManualEvaluation[]

  @@map("evaluation_reports")
}

model ReportScore {
  scoreId     Int                  @id @default(autoincrement()) @map("score_id")
  reportId    Int                  @map("report_id")
  criterionId Int?                 @map("criterion_id")
  score       Int
  rationale   String?
  report      EvaluationReport     @relation(fields: [reportId], references: [reportId])
  criterion   EvaluationCriterion? @relation(fields: [criterionId], references: [criterionId])
  evidences   ReportEvidence[]

  @@map("report_scores")
}

model ReportEvidence {
  evidenceId   Int              @id @default(autoincrement()) @map("evidence_id")
  scoreId      Int              @map("score_id")
  answerId     Int?             @map("answer_id")
  evidenceText String           @map("evidence_text")
  score        ReportScore      @relation(fields: [scoreId], references: [scoreId])
  answer       InterviewAnswer? @relation(fields: [answerId], references: [answerId])

  @@map("report_evidences")
}

model ManualEvaluation {
  manualEvalId   Int                @id @default(autoincrement()) @map("manual_eval_id")
  reportId       Int                @map("report_id")
  reviewerUserId Int                @map("reviewer_user_id")
  decision       ScreeningDecision?
  memo           String?
  reviewedAt     DateTime?          @map("reviewed_at")
  report         EvaluationReport   @relation(fields: [reportId], references: [reportId])
  reviewer       User               @relation(fields: [reviewerUserId], references: [userId])

  @@map("manual_evaluations")
}

model Notification {
  notificationId   Int                 @id @default(autoincrement()) @map("notification_id")
  userId           Int                 @map("user_id")
  applicationId    Int?                @map("application_id")
  channel          NotificationChannel
  notificationType String              @map("notification_type") @db.VarChar(80)
  status           String              @db.VarChar(40)
  sentAt           DateTime?           @map("sent_at")
  user             User                @relation(fields: [userId], references: [userId])
  application      Application?        @relation(fields: [applicationId], references: [applicationId])

  @@map("notifications")
}

model AiProcessLog {
  processLogId Int             @id @default(autoincrement()) @map("process_log_id")
  applicationId Int?           @map("application_id")
  sessionId     Int?           @map("session_id")
  processType   AiProcessType  @map("process_type")
  status        AiProcessStatus @default(PENDING)
  inputRef      String?        @map("input_ref")
  outputRef     String?        @map("output_ref")
  createdAt     DateTime       @default(now()) @map("created_at")
  application   Application?   @relation(fields: [applicationId], references: [applicationId])
  session       InterviewSession? @relation(fields: [sessionId], references: [sessionId])
  guardrailLogs AiGuardrailLog[]

  @@map("ai_process_logs")
}

model AiGuardrailLog {
  guardrailLogId Int             @id @default(autoincrement()) @map("guardrail_log_id")
  processLogId   Int             @map("process_log_id")
  policyName     String          @map("policy_name") @db.VarChar(120)
  result         GuardrailResult
  reason         String?
  createdAt      DateTime        @default(now()) @map("created_at")
  processLog     AiProcessLog    @relation(fields: [processLogId], references: [processLogId])

  @@map("ai_guardrail_logs")
}

model Embedding {
  embeddingId        Int                 @id @default(autoincrement()) @map("embedding_id")
  postingId          Int?                @map("posting_id")
  tagId              Int?                @map("tag_id")
  questionId         Int?                @map("question_id")
  documentId         Int?                @map("document_id")
  answerId           Int?                @map("answer_id")
  reportId           Int?                @map("report_id")
  sourceType         EmbeddingSourceType @map("source_type")
  sourceTextHash     String              @map("source_text_hash") @db.VarChar(128)
  embeddingModel     String              @map("embedding_model") @db.VarChar(120)
  embeddingDimension Int                 @map("embedding_dimension")
  embeddingVector    String              @map("embedding_vector")
  metadataJson       String?             @map("metadata_json")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@map("embeddings")
}
