# Runtime
NODE_ENV=development
PORT=3001
WORKER_CONCURRENCY=2

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://init:init@localhost:5432/init?schema=public

# Cache
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=local-dev-jwt-secret-change-me
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=14d

# AWS compatible local/dev settings
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=init-local-assets
SQS_QUEUE_URL=http://localhost:4566/000000000000/init-ai-jobs

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Media / Upload
MAX_UPLOAD_BYTES=104857600
SIGNED_URL_TTL_SECONDS=900
