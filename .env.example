# Runtime
NODE_ENV=development
PORT=3001
WORKER_CONCURRENCY=2

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://init:init@localhost:5432/init?schema=public

# Cache
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=local-dev-jwt-secret-change-me
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=14d
AUTH_REFRESH_COOKIE_NAME=refreshToken
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_APPLICATION_MAGIC_LINK_TTL_SECONDS=604800

# Public interview access
PUBLIC_APPLICATION_TOKEN_VERIFY_URL=http://localhost:3001/api/v1/public/applications/token/verify
PUBLIC_APPLICATION_TOKEN_VERIFY_SECRET=
PUBLIC_APPLICATION_TOKEN_SECRET=local-dev-jwt-secret-change-me
PUBLIC_INTERVIEW_ACCESS_TOKEN_SECRET=local-dev-jwt-secret-change-me
PUBLIC_INTERVIEW_ACCESS_TOKEN_TTL_SECONDS=3600

# Google OAuth (candidate accounts only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# SMTP email delivery
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@init.local

# AWS compatible local/dev settings
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:14566
S3_BUCKET=init-local-assets
S3_BUCKET_NAME=init-local-assets
S3_PUBLIC_BASE_URL=http://localhost:14566/init-local-assets
AI_SQS_QUEUE_URL=http://localhost:14566/000000000000/init-ai-jobs
SQS_QUEUE_URL=http://localhost:14566/000000000000/init-ai-jobs

# AI
AI_PROVIDER_MODE=mock
OPENAI_API_KEY=
AI_PROVIDER_API_KEY=local-dev-placeholder
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_STT_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_LANGUAGE=ko

# Worker
WORKER_REPOSITORY_MODE=prisma
WORKER_BATCH_SIZE=1
WORKER_POLL_INTERVAL_MS=1000

# Media / Upload
MAX_UPLOAD_BYTES=104857600
JD_IMAGE_MAX_UPLOAD_BYTES=5242880
SIGNED_URL_TTL_SECONDS=900
